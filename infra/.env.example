# =============================================================================
# BIGDATA LAKEHOUSE PLATFORM - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# --- Project ---
COMPOSE_PROJECT_NAME=lakehouse
PLATFORM_VERSION=1.0.0

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=airflow_db
POSTGRES_USER=airflow_user
POSTGRES_PASSWORD=airflow_secure_pass_2024
POSTGRES_AIRFLOW_SCHEMA=airflow

# --- MinIO ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secure_pass_2024
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here-generate-with-python
AIRFLOW__WEBSERVER__SECRET_KEY=your-webserver-secret-key-here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin_secure_2024
AIRFLOW_ADMIN_EMAIL=admin@lakehouse.local
AIRFLOW_WEBSERVER_PORT=8080

# --- Spark ---
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8081
SPARK_WORKER_WEBUI_PORT=8082
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g

# --- JupyterLab ---
JUPYTER_TOKEN=jupyter_secure_token_2024
JUPYTER_PORT=8888

# --- Multi-repo: caminhos absolutos dos repositórios separados ---
# Execute scripts/setup-repos.sh para preencher automaticamente
PIPELINES_REPO=/absolute/path/to/lakehouse-pipelines

# --- GitHub (notebooks) ---
# GIT_USER_NAME and GIT_USER_EMAIL são usados no git config dentro do container
# GITHUB_TOKEN: Personal Access Token com escopo "repo" (ou "Contents: read/write" para fine-grained)
# Gere em: https://github.com/settings/tokens
GIT_USER_NAME=your_github_username
GIT_USER_EMAIL=your@email.com
GITHUB_TOKEN=ghp_your_personal_access_token_here

# --- Notebook Runner (Papermill via REST API) ---
NOTEBOOK_RUNNER_MEM_LIMIT=1g

# --- Hive Metastore ---
HMS_DB_NAME=hive_metastore_db
HMS_DB_USER=hive_user
HMS_DB_PASSWORD=hive_pass_2024
HMS_MEM_LIMIT=512m

# --- Trino ---
TRINO_PORT=8084
TRINO_MEM_LIMIT=2g

# --- Superset ---
SUPERSET_PORT=8088
SUPERSET_SECRET_KEY=change_me_to_a_long_random_string
SUPERSET_DB_NAME=superset_db
SUPERSET_DB_USER=superset_user
SUPERSET_DB_PASSWORD=superset_pass_2024
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=superset_admin_2024
SUPERSET_ADMIN_EMAIL=admin@lakehouse.local
SUPERSET_MEM_LIMIT=1g

# --- OpenMetadata ---
OPENMETADATA_PORT=8585
OPENMETADATA_DB_NAME=openmetadata_db
OPENMETADATA_DB_USER=openmetadata_user
OPENMETADATA_DB_PASSWORD=openmetadata_pass_2024
OPENMETADATA_MEM_LIMIT=2g

# --- Elasticsearch ---
ELASTICSEARCH_MEM_LIMIT=1g

# --- Iceberg ---
ICEBERG_WAREHOUSE=s3a://gold/warehouse
ICEBERG_CATALOG_NAME=lakehouse

# --- Monitoring ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_secure_2024
PROMETHEUS_PORT=9090
LOKI_PORT=3100

# --- Cloudflare Tunnel ---
# Get token from: https://one.dash.cloudflare.com -> Zero Trust -> Networks -> Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# --- Security Stack (Keycloak + Ranger) ---
# Ativado com: docker compose -f docker-compose.yml -f docker-compose.security.yml up -d
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=keycloak_admin_2024
KEYCLOAK_DB_NAME=keycloak_db
KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=keycloak_pass_2024
# Segredos dos clients OIDC — deve coincidir com realm-lakehouse.json
KEYCLOAK_AIRFLOW_CLIENT_SECRET=airflow-client-secret-change-me
KEYCLOAK_TRINO_CLIENT_SECRET=trino-client-secret-change-me
KEYCLOAK_SUPERSET_CLIENT_SECRET=superset-client-secret-change-me
KEYCLOAK_GRAFANA_CLIENT_SECRET=grafana-client-secret-change-me
RANGER_PORT=6080
RANGER_DB_NAME=ranger_db
RANGER_DB_USER=ranger_user
RANGER_DB_PASSWORD=ranger_pass_2024
RANGER_ADMIN_USER=admin
RANGER_ADMIN_PASSWORD=rangerR0cks!
SOLR_PORT=8983

# --- Resource Limits ---
POSTGRES_MEM_LIMIT=512m
POSTGRES_CPU_LIMIT=0.5
MINIO_MEM_LIMIT=1g
MINIO_CPU_LIMIT=1.0
AIRFLOW_SCHEDULER_MEM_LIMIT=1g
AIRFLOW_WEBSERVER_MEM_LIMIT=1g
AIRFLOW_WORKER_MEM_LIMIT=2g
SPARK_MASTER_MEM_LIMIT=512m
SPARK_WORKER_MEM_LIMIT=3g
JUPYTER_MEM_LIMIT=2g
PROMETHEUS_MEM_LIMIT=512m
GRAFANA_MEM_LIMIT=256m
LOKI_MEM_LIMIT=256m
