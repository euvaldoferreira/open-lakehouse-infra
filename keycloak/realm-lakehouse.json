{
  "realm": "lakehouse",
  "displayName": "Lakehouse Platform",
  "displayNameHtml": "<b>Lakehouse</b> Platform",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 3600,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrador da plataforma — acesso total"
      },
      {
        "name": "data-engineer",
        "description": "Engenheiro de dados — acesso a pipelines e dados brutos"
      },
      {
        "name": "data-analyst",
        "description": "Analista de dados — acesso a dados processados e dashboards"
      },
      {
        "name": "viewer",
        "description": "Leitor — acesso somente leitura a dashboards"
      }
    ]
  },

  "groups": [
    {
      "name": "admins",
      "realmRoles": ["admin"]
    },
    {
      "name": "data-engineers",
      "realmRoles": ["data-engineer"]
    },
    {
      "name": "analysts",
      "realmRoles": ["data-analyst"]
    },
    {
      "name": "viewers",
      "realmRoles": ["viewer"]
    }
  ],

  "clients": [
    {
      "clientId": "airflow",
      "name": "Apache Airflow",
      "enabled": true,
      "publicClient": false,
      "secret": "airflow-client-secret-change-me",
      "redirectUris": ["http://localhost:8080/oauth-authorized/keycloak"],
      "webOrigins": ["http://localhost:8080"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "trino",
      "name": "Trino Query Engine",
      "enabled": true,
      "publicClient": false,
      "secret": "trino-client-secret-change-me",
      "redirectUris": ["http://localhost:8084/oauth2/callback"],
      "webOrigins": ["http://localhost:8084"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "superset",
      "name": "Apache Superset",
      "enabled": true,
      "publicClient": false,
      "secret": "superset-client-secret-change-me",
      "redirectUris": ["http://localhost:8088/oauth-authorized/keycloak"],
      "webOrigins": ["http://localhost:8088"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "grafana",
      "name": "Grafana",
      "enabled": true,
      "publicClient": false,
      "secret": "grafana-client-secret-change-me",
      "redirectUris": ["http://localhost:3000/login/generic_oauth"],
      "webOrigins": ["http://localhost:3000"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "openmetadata",
      "name": "OpenMetadata",
      "enabled": true,
      "publicClient": false,
      "secret": "openmetadata-client-secret-change-me",
      "redirectUris": ["http://localhost:8585/callback"],
      "webOrigins": ["http://localhost:8585"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "ranger",
      "name": "Apache Ranger",
      "enabled": true,
      "publicClient": false,
      "secret": "ranger-client-secret-change-me",
      "redirectUris": ["http://localhost:6080/ranger/callbacks/oidc"],
      "webOrigins": ["http://localhost:6080"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    }
  ],

  "users": [
    {
      "username": "admin",
      "email": "admin@lakehouse.local",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin_lakehouse_2024",
          "temporary": true
        }
      ],
      "groups": ["/admins"],
      "realmRoles": ["admin"]
    },
    {
      "username": "engineer1",
      "email": "engineer1@lakehouse.local",
      "firstName": "Data",
      "lastName": "Engineer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "engineer_2024",
          "temporary": true
        }
      ],
      "groups": ["/data-engineers"],
      "realmRoles": ["data-engineer"]
    },
    {
      "username": "analyst1",
      "email": "analyst1@lakehouse.local",
      "firstName": "Data",
      "lastName": "Analyst",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "analyst_2024",
          "temporary": true
        }
      ],
      "groups": ["/analysts"],
      "realmRoles": ["data-analyst"]
    }
  ],

  "defaultRoles": ["viewer"],

  "passwordPolicy": "length(8) and notUsername",

  "smtpServer": {},

  "identityProviders": [],

  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "foo",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ]
}
